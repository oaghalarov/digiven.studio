<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Digiven Studio — Digital Venture Studio</title>
  <meta name="description" content="We find gaps. We build fast. We launch real. Digiven Studio is a digital venture studio focused on building and testing high-value products.">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0A0C0B;
      --bg-elevate: #111413;
      --bg-elevate-hover: #161a18;
      --accent: #C8F06A;
      --accent-dim: rgba(200, 240, 106, 0.06);
      --accent-border: rgba(200, 240, 106, 0.15);
      --ink: #F2F0EB;
      --muted: #6B7D70;
      --border: rgba(242, 240, 235, 0.06);
      --border-hover: rgba(242, 240, 235, 0.15);
      
      --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'DM Mono', monospace;
      
      --r-sm: 6px;
      --r-md: 12px;
      --r-lg: 20px;
      
      --transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      --max-width: 1200px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg);
    }

    body {
      font-family: var(--font-sans);
      background-color: var(--bg);
      color: var(--ink);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Noise overlay for premium analog feel */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.7;
    }

    /* Scroll Reveal Animation base classes */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    .delay-1 { transition-delay: 0.1s; }
    .delay-2 { transition-delay: 0.2s; }
    .delay-3 { transition-delay: 0.3s; }
    .delay-4 { transition-delay: 0.4s; }

    /* Utility typography styles */
    .font-mono {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .section-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .section-eyebrow::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
    }

    /* Layout Containers */
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 40px;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 24px;
      }
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      background: rgba(10, 12, 11, 0.75);
      border-bottom: 1px solid var(--border);
      transition: var(--transition);
    }

    .nav-container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 40px;
      height: 72px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }

    @media (max-width: 768px) {
      .nav-container {
        padding: 0 24px;
        height: 64px;
      }
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      justify-self: start;
    }

    .logo-mark {
      width: 34px;
      height: 34px;
      flex-shrink: 0;
    }

    .logo-wordmark {
      font-size: 18px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.02em;
    }

    .logo-suffix {
      color: var(--muted);
      font-weight: 400;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
      justify-self: center;
    }

    .nav-links a {
      font-size: 13px;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: var(--transition);
    }

    .nav-links a:hover {
      color: var(--ink);
    }

    .nav-cta {
      font-size: 12px;
      font-weight: 500;
      padding: 9px 18px;
      border-radius: var(--r-sm);
      background: var(--accent);
      color: var(--bg);
      border: 1px solid var(--accent);
      cursor: pointer;
      font-family: var(--font-sans);
      letter-spacing: 0.01em;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 6px;
      justify-self: end;
    }

    .nav-cta:hover {
      background: transparent;
      color: var(--accent);
      box-shadow: 0 0 16px rgba(200, 240, 106, 0.2);
    }

    /* Burger Menu Mobile */
    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      flex-direction: column;
      gap: 5px;
      z-index: 101;
    }

    .mobile-menu-btn span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--ink);
      transition: var(--transition);
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }
      .nav-cta {
        display: none;
      }
      .mobile-menu-btn {
        display: flex;
      }
    }

    /* Mobile Overlay Menu */
    .mobile-nav-overlay {
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 99;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 32px;
      opacity: 0;
      pointer-events: none;
      transition: var(--transition);
    }

    .mobile-nav-overlay.active {
      opacity: 1;
      pointer-events: all;
    }

    .mobile-nav-links {
      list-style: none;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .mobile-nav-links a {
      font-size: 24px;
      color: var(--ink);
      text-decoration: none;
      font-weight: 500;
      transition: var(--transition);
    }

    .mobile-nav-links a:hover {
      color: var(--accent);
    }

    .mobile-nav-cta {
      margin-top: 16px;
      font-size: 14px;
      padding: 12px 28px;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 140px 0 100px;
      overflow: hidden;
    }

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image: 
        linear-gradient(rgba(242, 240, 235, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(242, 240, 235, 0.015) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(circle at 50% 50%, black 30%, transparent 100%);
      -webkit-mask-image: radial-gradient(circle at 50% 50%, black 30%, transparent 100%);
      pointer-events: none;
      z-index: 1;
    }

    .hero-glow-1 {
      position: absolute;
      top: -150px;
      right: -50px;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(200, 240, 106, 0.06) 0%, transparent 70%);
      filter: blur(80px);
      pointer-events: none;
      z-index: 1;
    }

    .hero-glow-2 {
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(107, 125, 112, 0.08) 0%, transparent 70%);
      filter: blur(100px);
      pointer-events: none;
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 900px;
    }

    .hero-title {
      font-size: clamp(44px, 8vw, 84px);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 24px;
    }

    .hero-title .accent-span {
      color: var(--accent);
    }

    .hero-title .muted-span {
      color: var(--muted);
      font-weight: 500;
    }

    .hero-sub {
      font-size: clamp(16px, 2.5vw, 19px);
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
      max-width: 580px;
      margin-bottom: 44px;
    }

    .hero-sub strong {
      color: var(--ink);
      font-weight: 450;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 500;
      padding: 15px 32px;
      border-radius: var(--r-sm);
      text-decoration: none;
      font-family: var(--font-sans);
      transition: var(--transition);
      cursor: pointer;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--bg);
      border: 1px solid var(--accent);
    }

    .btn-primary:hover {
      background: transparent;
      color: var(--accent);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(200, 240, 106, 0.2);
    }

    /* ── SCROLLING MARQUEE ── */
    .marquee-section {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: #080a09;
      padding: 24px 0;
      overflow: hidden;
      width: 100vw;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
    }

    .marquee {
      display: flex;
      width: 100%;
      overflow: hidden;
      user-select: none;
    }

    .marquee-content {
      flex-shrink: 0;
      display: flex;
      justify-content: space-around;
      min-width: 100%;
      gap: 40px;
      animation: scroll 32s linear infinite;
      align-items: center;
    }

    .marquee-item {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 0.12em;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 40px;
    }

    .marquee-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--accent);
      display: inline-block;
    }

    @keyframes scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-100%); }
    }

    /* ── SECTION CORE ── */
    section.py-sec {
      padding: 120px 0;
    }

    @media (max-width: 768px) {
      section.py-sec {
        padding: 80px 0;
      }
    }

    .section-header {
      margin-bottom: 64px;
    }

    .section-title {
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }

    .section-desc {
      font-size: 16px;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
      max-width: 580px;
    }

    /* ── HOW WE WORK ── */
    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    @media (max-width: 900px) {
      .how-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
    }

    .how-card {
      background: var(--bg-elevate);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 40px 32px;
      display: flex;
      flex-direction: column;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }

    .how-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0;
      transition: var(--transition);
    }

    .how-card:hover {
      border-color: var(--border-hover);
      background: var(--bg-elevate-hover);
      transform: translateY(-4px);
    }

    .how-card:hover::before {
      opacity: 1;
    }

    .how-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }

    .how-num {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid var(--accent-border);
      padding: 3px 10px;
      border-radius: 99px;
    }

    .how-stage {
      color: var(--muted);
    }

    .how-title {
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 12px;
      letter-spacing: -0.01em;
    }

    .how-body {
      font-size: 14px;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 24px;
      flex-grow: 1;
    }

    .how-tag {
      color: var(--ink);
      font-weight: 500;
      border-top: 1px solid var(--border);
      padding-top: 16px;
      font-size: 11px;
    }

    /* ── PRODUCTS ── */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    @media (max-width: 900px) {
      .products-grid {
        grid-template-columns: 1fr;
        gap: 20px;
      }
    }

    .product-card {
      background: var(--bg-elevate);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: var(--transition);
      cursor: default;
    }

    .product-card:hover {
      border-color: var(--border-hover);
      background: var(--bg-elevate-hover);
      transform: translateY(-4px);
    }

    /* Sleek Blueprint / Schematic Placeholder Graphic */
    .pc-blueprint {
      height: 200px;
      background: #0c0e0d;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid var(--border);
    }

    .blueprint-grid {
      position: absolute;
      inset: 0;
      background-size: 20px 20px;
      background-image: 
        linear-gradient(rgba(242, 240, 235, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(242, 240, 235, 0.015) 1px, transparent 1px);
    }

    .blueprint-status {
      position: absolute;
      top: 16px;
      left: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(10, 12, 11, 0.6);
      padding: 4px 10px;
      border-radius: 99px;
      border: 1px solid var(--border);
      backdrop-filter: blur(4px);
      z-index: 2;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }

    .status-dot.pulsing {
      animation: pulse-dot 2s infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 0.3; transform: scale(0.9); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    .status-text {
      font-size: 9px;
      color: var(--ink);
    }

    .blueprint-graphic {
      width: 120px;
      height: 120px;
      opacity: 0.45;
      transition: var(--transition);
    }

    .product-card:hover .blueprint-graphic {
      opacity: 0.8;
      transform: scale(1.05);
    }

    .pc-content {
      padding: 32px;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .pc-meta {
      color: var(--accent);
      margin-bottom: 10px;
    }

    .pc-title {
      font-size: 22px;
      font-weight: 600;
      margin-bottom: 10px;
      letter-spacing: -0.01em;
    }

    .pc-description {
      font-size: 14px;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 24px;
      flex-grow: 1;
    }

    .pc-footer {
      border-top: 1px solid var(--border);
      padding-top: 16px;
      color: var(--muted);
    }

    /* ── STUDIO MODEL ── */
    .model-wrap {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 80px;
      align-items: center;
    }

    @media (max-width: 900px) {
      .model-wrap {
        grid-template-columns: 1fr;
        gap: 56px;
      }
    }

    .model-points {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .mp-item {
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }

    .mp-num {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid var(--accent-border);
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .mp-title {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 6px;
      color: var(--ink);
    }

    .mp-body {
      font-size: 14px;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
    }

    /* Revamped Visual Orbital Graphic */
    .model-visual {
      position: relative;
      height: 460px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @media (max-width: 500px) {
      .model-visual {
        height: 340px;
      }
    }

    .mv-center {
      position: absolute;
      width: 130px;
      height: 130px;
      border-radius: 50%;
      background: rgba(10, 12, 11, 0.85);
      border: 1px solid var(--accent-border);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 5;
      box-shadow: 0 0 40px rgba(200, 240, 106, 0.08);
    }

    .mv-center-logo {
      width: 54px;
      height: 54px;
    }

    .mv-orbit {
      position: absolute;
      border-radius: 50%;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .mv-orbit-1 {
      width: 250px;
      height: 250px;
      animation: spin-clockwise 24s linear infinite;
    }

    .mv-orbit-2 {
      width: 390px;
      height: 390px;
      animation: spin-counter 36s linear infinite;
    }

    @media (max-width: 500px) {
      .mv-orbit-1 {
        width: 190px;
        height: 190px;
      }
      .mv-orbit-2 {
        width: 290px;
        height: 290px;
      }
    }

    .mv-node {
      position: absolute;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--bg-elevate);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
      color: var(--accent);
    }

    .mv-node:hover {
      border-color: var(--accent);
      background: var(--accent-dim);
      box-shadow: 0 0 16px rgba(200, 240, 106, 0.3);
      color: var(--ink);
    }

    .mv-node svg {
      width: 18px;
      height: 18px;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
    }

    /* Position nodes evenly along the orbits */
    /* Orbit 1 (4 nodes) */
    .mv-orbit-1 .mv-node:nth-child(1) { top: -21px; left: calc(50% - 21px); }
    .mv-orbit-1 .mv-node:nth-child(2) { bottom: -21px; left: calc(50% - 21px); }
    .mv-orbit-1 .mv-node:nth-child(3) { left: -21px; top: calc(50% - 21px); }
    .mv-orbit-1 .mv-node:nth-child(4) { right: -21px; top: calc(50% - 21px); }

    /* Orbit 2 (4 nodes) */
    .mv-orbit-2 .mv-node:nth-child(1) { top: 32px; left: 32px; }
    .mv-orbit-2 .mv-node:nth-child(2) { top: 32px; right: 32px; }
    .mv-orbit-2 .mv-node:nth-child(3) { bottom: 32px; left: 32px; }
    .mv-orbit-2 .mv-node:nth-child(4) { bottom: 32px; right: 32px; }

    @keyframes spin-clockwise {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @keyframes spin-counter {
      from { transform: rotate(360deg); }
      to { transform: rotate(0deg); }
    }

    /* ── CTA / CONTACT ── */
    .cta-section {
      position: relative;
      overflow: hidden;
    }

    .cta-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(200, 240, 106, 0.04) 0%, transparent 60%);
      filter: blur(80px);
      pointer-events: none;
      z-index: 1;
    }

    .cta-inner {
      position: relative;
      z-index: 2;
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
    }

    .cta-title {
      font-size: clamp(36px, 6vw, 60px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }

    .cta-title span {
      color: var(--accent);
    }

    .cta-sub {
      font-size: 16px;
